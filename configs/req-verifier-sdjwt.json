{
  "openId4VPProfile": "DEFAULT",
  "request_credentials": [
    {
      "format": "vc+sd-jwt",
      "vct": "identity_credential",
      "input_descriptor": {
        "id": "identity_credential",
        "format": {
          "vc+sd-jwt": {
            "sd-jwt_alg_values": ["EdDSA", "ES256"]
          }
        },
        "constraints": {
          "limit_disclosure": "required",
          "fields": [
            {
              "path": ["$.given_name"],
              "filter": {}
            },
            {
              "path": ["$.family_name"],
              "filter": {}
            },
            {
              "path": ["$.email"],
              "filter": {}
            }
          ]
        }
      }
    }
  ],
  "vp_policies": [],
  "vc_policies": [],
  "presentationID": "verification_session_$RANDOM_ID"
}